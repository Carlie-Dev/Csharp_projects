using System;
using System.Collections.Generic;
using System.Text;

namespace _006__Age_API_Practice
{
    internal class Age
    {   //order of variables in API
        int count;
        string name;
        int age;
        

        //default constructor
        public Age() { }

        // Constructor to initialize the Age object
        public Age(string name, int age, int count)
        {
            this.count = count;
            this.name = name;
            this.age = age;
            
        }

        public override string ToString()
        {
            return $"Name: {name}, Age: {age}, Count: {count}";
        }
    }
}
